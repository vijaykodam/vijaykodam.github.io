<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Piano on Vijay Kodam</title><link>https://vijay.eu/tags/piano/</link><description>Recent content in Piano on Vijay Kodam</description><generator>Hugo -- gohugo.io</generator><language>en</language><lastBuildDate>Thu, 26 Feb 2026 00:00:00 +0200</lastBuildDate><atom:link href="https://vijay.eu/tags/piano/index.xml" rel="self" type="application/rss+xml"/><item><title>Note Quest</title><link>https://vijay.eu/projects/note-quest/</link><pubDate>Thu, 26 Feb 2026 00:00:00 +0200</pubDate><guid>https://vijay.eu/projects/note-quest/</guid><description>&lt;p&gt;Learn to read music notes on the grand staff! Pick the correct note name for each question.&lt;/p&gt;
&lt;p&gt;Created using Claude Code CLI on 26th Feb 2026
&lt;link rel="stylesheet" href="https://vijay.eu/css/note-quest.css"&gt;
&lt;script src="https://cdn.jsdelivr.net/npm/vexflow/build/cjs/vexflow.js"&gt;&lt;/script&gt;
&lt;div class="note-quest-wrapper"&gt;
&lt;div class="nq-screen start-screen active" id="nqStartScreen"&gt;
&lt;label class="nq-helper-toggle"&gt;
&lt;input type="checkbox" id="nqShowNoteNames"&gt; Show note names on staff
&lt;small class="nq-helper-hint"&gt;Auto for Levels 1-2, 4&lt;/small&gt;
&lt;/label&gt;
&lt;div class="difficulty-btns"&gt;
&lt;div class="level-category"&gt;
&lt;h3 class="category-header easy"&gt;Easy&lt;/h3&gt;
&lt;button class="level-btn easy" data-level="1"&gt;
1 — First Notes &lt;small&gt;Treble · C4–G4&lt;/small&gt;
&lt;/button&gt;
&lt;button class="level-btn easy" data-level="2"&gt;
2 — Treble Basics &lt;small&gt;Treble · C4–C5&lt;/small&gt;
&lt;/button&gt;
&lt;button class="level-btn easy" data-level="3"&gt;
3 — Treble Comfort &lt;small&gt;Treble · C4–G5&lt;/small&gt;
&lt;/button&gt;
&lt;/div&gt;
&lt;div class="level-category"&gt;
&lt;h3 class="category-header medium"&gt;Medium&lt;/h3&gt;
&lt;button class="level-btn medium" data-level="4"&gt;
4 — Meet the Bass &lt;small&gt;Both clefs · F3–G4&lt;/small&gt;
&lt;/button&gt;
&lt;button class="level-btn medium" data-level="5"&gt;
5 — Grand Staff &lt;small&gt;Both clefs · C3–C5&lt;/small&gt;
&lt;/button&gt;
&lt;button class="level-btn medium" data-level="6"&gt;
6 — Expanding Range &lt;small&gt;Both clefs · A2–D5&lt;/small&gt;
&lt;/button&gt;
&lt;button class="level-btn medium" data-level="7"&gt;
7 — Full Staff &lt;small&gt;Both clefs · G2–E5&lt;/small&gt;
&lt;/button&gt;
&lt;/div&gt;
&lt;div class="level-category"&gt;
&lt;h3 class="category-header hard"&gt;Hard&lt;/h3&gt;
&lt;button class="level-btn hard" data-level="8"&gt;
8 — Ledger Lines &lt;small&gt;Both clefs · E2–G5&lt;/small&gt;
&lt;/button&gt;
&lt;button class="level-btn hard" data-level="9"&gt;
9 — Extended Range &lt;small&gt;Both clefs · E2–A5&lt;/small&gt;
&lt;/button&gt;
&lt;button class="level-btn hard" data-level="10"&gt;
10 — Note Master &lt;small&gt;Both clefs · E2–C6&lt;/small&gt;
&lt;/button&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;div class="nq-screen" id="nqGameScreen"&gt;
&lt;div class="nq-header"&gt;
&lt;div class="nq-logo"&gt;Note Quest&lt;/div&gt;
&lt;div class="nq-progress" id="nqProgress"&gt;1 / 10&lt;/div&gt;
&lt;/div&gt;
&lt;div class="nq-container"&gt;
&lt;div class="staff-card" id="nqStaffCard"&gt;&lt;/div&gt;
&lt;div class="choices" id="nqChoices"&gt;
&lt;button class="choice-btn" data-note="C"&gt;C&lt;/button&gt;
&lt;button class="choice-btn" data-note="D"&gt;D&lt;/button&gt;
&lt;button class="choice-btn" data-note="E"&gt;E&lt;/button&gt;
&lt;button class="choice-btn" data-note="F"&gt;F&lt;/button&gt;
&lt;button class="choice-btn" data-note="G"&gt;G&lt;/button&gt;
&lt;button class="choice-btn" data-note="A"&gt;A&lt;/button&gt;
&lt;button class="choice-btn" data-note="B"&gt;B&lt;/button&gt;
&lt;/div&gt;
&lt;div class="stats-bar"&gt;
&lt;span&gt;Streak: &lt;strong id="nqStreakDisplay"&gt;0&lt;/strong&gt;&lt;/span&gt;
&lt;span&gt;Score: &lt;strong id="nqScoreDisplay"&gt;0&lt;/strong&gt;&lt;/span&gt;
&lt;span id="nqTimerDisplay"&gt;0:00&lt;/span&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;div class="nq-screen results-screen" id="nqResultsScreen"&gt;
&lt;h2&gt;Round Complete!&lt;/h2&gt;
&lt;div class="stars" id="nqStarsDisplay"&gt;&lt;/div&gt;
&lt;div class="results-stats" id="nqResultsStats"&gt;&lt;/div&gt;
&lt;button class="play-again-btn"&gt;Play Again&lt;/button&gt;
&lt;/div&gt;
&lt;canvas id="nqConfetti"&gt;&lt;/canvas&gt;
&lt;/div&gt;
&lt;script src="https://vijay.eu/js/note-quest.js"&gt;&lt;/script&gt;
&lt;/p&gt;</description></item></channel></rss>